# Copy this file to ".env" and fill in your real key.
# NEVER commit the real ".env" file to GitHub.

OPENAI_API_KEY=sk-your-key-here

# Which model to use. Use gpt-4o-mini for cheaper testing, gpt-4o for final demo.
OPENAI_MODEL=gpt-4o-mini

# Shared secret required in the X-API-Key header for api_server.py's
# /scan and /snapshot endpoints (used by N8N automation). Set this to
# any random string — if left unset, a temporary one is generated each
# run and printed to the console (fine for quick local testing, but set
# this explicitly for anything you'll actually call from N8N repeatedly).
API_SERVER_KEY=change-this-to-a-random-string
